#!/usr/bin/env sh
# Abort the commit if any step fails.
set -e

# 1. Lint: the Vite bundle must compile cleanly.
npm run build --silent > /dev/null

# 2. Format: rewrite staged PHP with Pint, then re-stage what it changed.
STAGED_PHP=$(git diff --cached --name-only --diff-filter=ACM -- '*.php')
if [ -n "$STAGED_PHP" ]; then
    echo "$STAGED_PHP" | xargs vendor/bin/pint
    echo "$STAGED_PHP" | xargs git add
fi

# 3. Static analysis: PHPStan must pass.
# Use php directly so the hook works in Git-Bash on Windows (composer.bat not in POSIX PATH).
php vendor/bin/phpstan analyse --memory-limit=512M
