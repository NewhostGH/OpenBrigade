# OpenBrigade environment variables
# Copy this file to .env and edit as needed before running `docker compose up`
# Run `php artisan key:generate` on first install to set APP_KEY.

APP_NAME=OpenBrigade
APP_ENV=development # can be development OR production
APP_KEY=base64:A8oDA/qNrbo5TjFEfPD2nWqbdN+6Y0GvESCvD2plQss=
# Run: php artisan key:generate --show  and paste the output here
APP_DEBUG=true
APP_URL=http://localhost:8080
TRUST_PROXIES=*
APP_TIMEZONE=Europe/Paris
APP_LOCALE=fr

# Application port on the host
APP_PORT=8080

# DBGate (web DB browser) — only active when COMPOSE_PROFILES=development
DBGATE_PORT=8888

# Enable the development Docker Compose profile (starts DBGate)
COMPOSE_PROFILES=development

# Database settings
DB_CONNECTION=mariadb
DB_HOST=db
DB_PORT=3306
DB_NAME=openbrigade
DB_USER=openbrigade
DB_DATABASE=openbrigade
DB_USERNAME=openbrigade
DB_PASSWORD=CHANGE_ME
DB_ROOT_PASSWORD=CHANGE_ME_ROOT
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

# Optional: legacy source DB for row-count parity checks
# LEGACY_DB_HOST=legacy-db-host
# LEGACY_DB_PORT=3306
# LEGACY_DB_DATABASE=ebrigade_legacy
# LEGACY_DB_USERNAME=legacy_user
# LEGACY_DB_PASSWORD=legacy_password

# Upload limits (must match php.ini values)
MAX_UPLOAD_MB=20
MAX_LIST_ROWS=500

# Logging
LOG_CHANNEL=stack
LOG_LEVEL=debug

# Session settings
SESSION_DRIVER=database
SESSION_TABLE=sessions
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SAME_SITE=strict
SESSION_HTTP_ONLY=true
SESSION_SECURE_COOKIE=false

# SSL/TLS options for build/runtime tools
# Set NODE_TLS_REJECT_UNAUTHORIZED=0 only in trusted dev environments to ignore TLS certificate checks.
NODE_TLS_REJECT_UNAUTHORIZED=1
# Set COMPOSER_DISABLE_TLS=1 only when absolutely necessary (insecure).
COMPOSER_DISABLE_TLS=0
